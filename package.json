{
  "name": "claudebench",
  "version": "0.1.0",
  "description": "Stop arguing about prompts. Measure them. A reproducible, statistically-honest benchmark harness for Claude Code workflows (CLAUDE.md, prompts, memory). Wilson CIs, significance-tested verdicts, test-based grading, record/replay. Zero deps.",
  "type": "module",
  "bin": {
    "claudebench": "bin/claudebench.mjs"
  },
  "exports": {
    ".": "./src/index.mjs"
  },
  "files": [
    "bin/",
    "src/",
    "suites/",
    "fixtures/",
    "docs/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test test/scorer.test.mjs",
    "demo": "node bin/claudebench.mjs demo",
    "fixture": "node scripts/gen-fixture.mjs",
    "start": "node bin/claudebench.mjs"
  },
  "keywords": [
    "claude",
    "claude-code",
    "benchmark",
    "eval",
    "evals",
    "llm",
    "llm-eval",
    "prompt-engineering",
    "claude-md",
    "ab-testing",
    "statistics",
    "anthropic",
    "ai-tools",
    "developer-tools"
  ],
  "engines": {
    "node": ">=18"
  },
  "license": "MIT",
  "author": "Ingrid Toulotte (https://github.com/ingridtoulotte)",
  "homepage": "https://github.com/ingridtoulotte/claudebench#readme",
  "bugs": {
    "url": "https://github.com/ingridtoulotte/claudebench/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ingridtoulotte/claudebench.git"
  }
}
